"""
SRT Subtitle Parser and Validator with Production-Grade Quality.

This module provides robust parsing, validation, and representation of SRT subtitle files.
It includes comprehensive error handling, logging, type annotations, input validation,
and performance optimizations suitable for production environments.
"""

import re
import logging
from dataclasses import dataclass, field
from typing import List, Optional, Sequence
from functools import lru_cache

# Configure logger for this module
logger = logging.getLogger(__name__)
logger.addHandler(logging.NullHandler())  # Prevent propagation if no handler set

# Constants for validation
MAX_LINE_LENGTH = 2000  # Max characters per subtitle block
MAX_TEXT_LENGTH = 500  # Max characters per subtitle text line
MAX_SUBTITLE_ENTRIES = 100_000  # Safety limit to prevent memory exhaustion
VALID_TIMESTAMP_PATTERN = re.compile(
    r'^(\d{2}):(\d{2}):(\d{2}),(\d{3})$'
)
SRT_BLOCK_SEPARATOR = re.compile(r'\n\s*\n')  # Two newlines with possible spaces


@dataclass(frozen=True)
class Timestamp:
    """Represents a timestamp in SRT format (HH:MM:SS,mmm)."""
    hours: int
    minutes: int
    seconds: int
    milliseconds: int

    def __post_init__(self) -> None:
        """Validate timestamp components after initialization."""
        if not (0 <= self.hours <= 99):
            raise ValueError(f"Hours out of range: {self.hours}")
        if not (0 <= self.minutes <= 59):
            raise ValueError(f"Minutes out of range: {self.minutes}")
        if not (0 <= self.seconds <= 59):
            raise ValueError(f"Seconds out of range: {self.seconds}")
        if not (0 <= self.milliseconds <= 999):
            raise ValueError(f"Milliseconds out of range: {self.milliseconds}")

    def to_srt_string(self) -> str:
        """Return formatted SRT timestamp string."""
        return f"{self.hours:02d}:{self.minutes:02d}:{self.seconds:02d},{self.milliseconds:03d}"

    def total_milliseconds(self) -> int:
        """Return total time in milliseconds."""
        return (self.hours * 3600 + self.minutes * 60 + self.seconds) * 1000 + self.milliseconds


@dataclass(frozen=True)
class SubtitleEntry:
    """Represents a single SRT subtitle entry with index, timestamps, and text."""
    index: int
    start: Timestamp
    end: Timestamp
    text: str = field(hash=False)

    def __post_init__(self) -> None:
        """Validate entry after initialization."""
        if self.index < 1:
            raise ValueError(f"Subtitle index must be positive: {self.index}")
        if self.start.total_milliseconds() >= self.end.total_milliseconds():
            raise ValueError(
                f"Start time ({self.start}) must be before end time ({self.end})"
            )
        if not self.text.strip():
            raise ValueError("Subtitle text cannot be empty")
        if len(self.text) > MAX_TEXT_LENGTH:
            raise ValueError(f"Subtitle text exceeds max length of {MAX_TEXT_LENGTH}")

    def to_srt_block(self) -> str:
        """Return full SRT block string for this entry."""
        lines = [str(self.index), f"{self.start.to_srt_string()} --> {self.end.to_srt_string()}", self.text]
        return '\n'.join(lines)


class SRTParseError(Exception):
    """Custom exception for SRT parsing failures."""


class SRTValidator:
    """
    Validates and parses SRT subtitle content.
    Implements rules from the SRT specification and adds additional safety checks.
    """

    @staticmethod
    def parse_timestamp(timestamp_str: str) -> Timestamp:
        """
        Parse a timestamp string into a Timestamp object.

        Args:
            timestamp_str: Timestamp in HH:MM:SS,mmm format.

        Returns:
            Parsed Timestamp object.

        Raises:
            ValueError: If format is invalid.
        """
        match = VALID_TIMESTAMP_PATTERN.match(timestamp_str)
        if not match:
            raise ValueError(f"Invalid timestamp format: {timestamp_str!r}")
        groups = match.groups()
        return Timestamp(
            hours=int(groups[0]),
            minutes=int(groups[1]),
            seconds=int(groups[2]),
            milliseconds=int(groups[3])
        )

    @classmethod
    def parse_block(cls, block_text: str) -> SubtitleEntry:
        """
        Parse a single SRT block into a SubtitleEntry.

        Args:
            block_text: Raw text of one SRT block (index + timestamps + text).

        Returns:
            Parsed SubtitleEntry.

        Raises:
            SRTParseError: If block cannot be parsed.
        """
        lines = block_text.strip().split('\n')
        if len(lines) < 3:
            raise SRTParseError(f"Block too few lines ({len(lines)}). Need at least 3.")

        # Pad lines if text spans multiple lines (join with newline)
        index_line = lines[0]
        time_line = lines[1]
        text_lines = lines[2:]

        # Parse index
        try:
            idx = int(index_line.strip())
        except ValueError as exc:
            raise SRTParseError(f"Invalid subtitle index: {index_line!r}") from exc

        if idx < 1:
            raise SRTParseError(f"Subtitle index must be positive: {idx}")

        # Parse timestamps
        # Expected format: "00:00:02,000 --> 00:00:07,000"
        if ' --> ' not in time_line:
            raise SRTParseError(f"Invalid timestamp line: {time_line!r}")
        parts = time_line.split(' --> ', maxsplit=1)
        if len(parts) != 2:
            raise SRTParseError(f"Invalid timestamp separator: {time_line!r}")

        start_str, end_str = parts
        try:
            start = cls.parse_timestamp(start_str.strip())
            end = cls.parse_timestamp(end_str.strip())
        except ValueError as exc:
            raise SRTParseError(f"Timestamp parse error: {exc}") from exc

        # Combine text lines
        text = '\n'.join(text_lines).strip()
        if not text:
            raise SRTParseError("Empty text after timestamps")

        # Truncate text if too long (security) but log warning
        if len(text) > MAX_TEXT_LENGTH:
            logger.warning(
                "Text too long in entry %d (%d chars). Truncating to %d.",
                idx, len(text), MAX_TEXT_LENGTH
            )
            text = text[:MAX_TEXT_LENGTH]

        return SubtitleEntry(index=idx, start=start, end=end, text=text)

    @classmethod
    def parse_srt(cls, content: str) -> List[SubtitleEntry]:
        """
        Parse a complete SRT content string into a list of SubtitleEntry objects.

        Args:
            content: Full SRT subtitle text.

        Returns:
            List of parsed subtitle entries, in order.

        Raises:
            SRTParseError: If content is empty or contains invalid blocks.
            ValueError: If content exceeds safety limits.
        """
        if not content or not content.strip():
            raise SRTParseError("SRT content is empty")

        # Security: limit maximum input size to prevent DoS
        if len(content) > MAX_LINE_LENGTH * MAX_SUBTITLE_ENTRIES:  # approx 200MB
            raise ValueError(f"SRT content too large ({len(content)} chars)")

        # Split into blocks using blank lines as separator
        raw_blocks = SRT_BLOCK_SEPARATOR.split(content.strip())
        entries: List[SubtitleEntry] = []
        seen_indices: set = set()

        for idx, block in enumerate(raw_blocks, start=1):
            if not block.strip():
                continue
            try:
                entry = cls.parse_block(block)
            except (SRTParseError, ValueError) as exc:
                logger.error("Failed to parse block %d: %s", idx, exc)
                continue  # Skip malformed blocks (configurable: could raise)

            # Duplicate index check
            if entry.index in seen_indices:
                logger.warning("Duplicate subtitle index %d detected. Using first occurrence.", entry.index)
                continue
            seen_indices.add(entry.index)

            entries.append(entry)

        # Sort by index (optional but good practice)
        entries.sort(key=lambda e: e.index)

        if not entries:
            raise SRTParseError("No valid subtitle entries found in content")

        # Safety limit on number of entries
        if len(entries) > MAX_SUBTITLE_ENTRIES:
            raise ValueError(f"Too many subtitle entries ({len(entries)} > {MAX_SUBTITLE_ENTRIES})")

        return entries


def srt_to_clean_text(entries: Sequence[SubtitleEntry]) -> str:
    """
    Convert list of SubtitleEntry to a clean text representation (plain text).

    Args:
        entries: Sequence of SubtitleEntry objects.

    Returns:
        Text content with timestamps removed.
    """
    return '\n'.join(entry.text for entry in entries)


